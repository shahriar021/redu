{
  "info": {
    "name": "JobsiteX Backend",
    "_postman_id": "jobsitex-backend-collection",
    "description": "Complete API collection for JobsiteX trucking platform backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.jobsitex.co/api/v1", "type": "string" },
    { "key": "socketUrl", "value": "https://api.jobsitex.co", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "otp", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.otp) pm.collectionVariables.set('otp', res.data.otp);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"mobileNumber\": \"+11234567890\",\n  \"password\": \"Password1\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] }
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"code\": \"{{otp}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["auth", "verify-otp"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password1\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Google OAuth (Web) - Redirect",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/google", "host": ["{{baseUrl}}"], "path": ["auth", "google"] },
            "description": "Opens browser Google OAuth flow — visit this URL in a browser, not Postman"
          }
        },
        {
          "name": "Google OAuth (Web) - Callback",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/google/callback?code=<google-auth-code>",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google", "callback"],
              "query": [{ "key": "code", "value": "<google-auth-code>" }]
            },
            "description": "Handled automatically by Google redirect — not called directly"
          }
        },
        {
          "name": "Google Mobile Auth",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"<google-id-token>\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/google/mobile", "host": ["{{baseUrl}}"], "path": ["auth", "google", "mobile"] }
          }
        },
        {
          "name": "Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.otp) pm.collectionVariables.set('otp', res.data.otp);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"code\": \"123456\",\n  \"newPassword\": \"NewPassword1\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/user/profile", "host": ["{{baseUrl}}"], "path": ["user", "profile"] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "fullName", "value": "Jane Doe", "type": "text" },
                { "key": "mobileNumber", "value": "+11234567890", "type": "text" },
                { "key": "avatar", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/user/profile", "host": ["{{baseUrl}}"], "path": ["user", "profile"] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Password1\",\n  \"newPassword\": \"NewPassword1\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/user/change-password", "host": ["{{baseUrl}}"], "path": ["user", "change-password"] }
          }
        },
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/user/notifications?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["user", "notifications"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/user/notifications/:id/read", "host": ["{{baseUrl}}"], "path": ["user", "notifications", ":id", "read"], "variable": [{ "key": "id", "value": "<notification-id>" }] }
          }
        },
        {
          "name": "Mark All Notifications Read",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/user/notifications/read-all", "host": ["{{baseUrl}}"], "path": ["user", "notifications", "read-all"] }
          }
        },
        {
          "name": "Update FCM Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fcmToken\": \"ExponentPushToken[xxxxxxxxxxxxxxxxxxxxxx]\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/user/fcm-token", "host": ["{{baseUrl}}"], "path": ["user", "fcm-token"] }
          }
        }
      ]
    },
    {
      "name": "Driver",
      "item": [
        {
          "name": "Get Driver Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/driver/profile", "host": ["{{baseUrl}}"], "path": ["driver", "profile"] }
          }
        },
        {
          "name": "Complete Driver Profile",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "truckTypeId", "value": "<truck-type-id>", "type": "text" },
                { "key": "numberPlate", "value": "ABC-1234", "type": "text" },
                { "key": "truckModel", "value": "Freightliner Cascadia", "type": "text" },
                { "key": "truckWeight", "value": "30000", "type": "text" },
                { "key": "trailerType", "value": "Flatbed", "type": "text" },
                { "key": "hourlyRate", "value": "75", "type": "text" },
                { "key": "cdlLicense", "type": "file", "src": "" },
                { "key": "insurance", "type": "file", "src": "" },
                { "key": "dotNumber", "type": "file", "src": "" },
                { "key": "truckPhoto", "type": "file", "src": "" },
                { "key": "truckPhotoMain", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/driver/profile/complete", "host": ["{{baseUrl}}"], "path": ["driver", "profile", "complete"] }
          }
        },
        {
          "name": "Set Availability",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isAvailable\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/driver/availability", "host": ["{{baseUrl}}"], "path": ["driver", "availability"] }
          }
        },
        {
          "name": "Update Location",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060\n}"
            },
            "url": { "raw": "{{baseUrl}}/driver/location", "host": ["{{baseUrl}}"], "path": ["driver", "location"] }
          }
        },
        {
          "name": "Get Earnings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/driver/earnings", "host": ["{{baseUrl}}"], "path": ["driver", "earnings"] }
          }
        },
        {
          "name": "Stripe — Get Onboarding Link",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/driver/stripe/onboarding-link",
              "host": ["{{baseUrl}}"],
              "path": ["driver", "stripe", "onboarding-link"]
            },
            "description": "Returns a Stripe Connect onboarding URL. Driver must have completed their profile and been admin-approved."
          }
        },
        {
          "name": "Stripe — Complete Onboarding (manual fallback)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/driver/stripe/complete-onboarding", "host": ["{{baseUrl}}"], "path": ["driver", "stripe", "complete-onboarding"] },
            "description": "Manual fallback — normally onboarding status is auto-synced via the account.updated Stripe webhook."
          }
        },
        {
          "name": "Stripe — Get Status",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/driver/stripe/status", "host": ["{{baseUrl}}"], "path": ["driver", "stripe", "status"] }
          }
        }
      ]
    },
    {
      "name": "Fare",
      "item": [
        {
          "name": "Get Truck Types",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/fare/truck-types", "host": ["{{baseUrl}}"], "path": ["fare", "truck-types"] }
          }
        },
        {
          "name": "Estimate Fare",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/fare/estimate?truckTypeId=<id>&pickupLat=40.7128&pickupLng=-74.0060&dropoffLat=40.7580&dropoffLng=-73.9855",
              "host": ["{{baseUrl}}"],
              "path": ["fare", "estimate"],
              "query": [
                { "key": "truckTypeId", "value": "<id>" },
                { "key": "pickupLat", "value": "40.7128" },
                { "key": "pickupLng", "value": "-74.0060" },
                { "key": "dropoffLat", "value": "40.7580" },
                { "key": "dropoffLng", "value": "-73.9855" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job (Broadcast)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupAddress\": \"123 Main St, New York, NY\",\n  \"pickupLat\": 40.7128,\n  \"pickupLng\": -74.0060,\n  \"dropoffAddress\": \"456 Broadway, New York, NY\",\n  \"dropoffLat\": 40.7580,\n  \"dropoffLng\": -73.9855,\n  \"truckTypeId\": \"<truck-type-id>\",\n  \"workNote\": \"Handle with care\",\n  \"scheduledAt\": \"2026-05-01T09:00:00.000Z\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/jobs", "host": ["{{baseUrl}}"], "path": ["jobs"] }
          }
        },
        {
          "name": "Create Job (Direct to Driver)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupAddress\": \"123 Main St, New York, NY\",\n  \"pickupLat\": 40.7128,\n  \"pickupLng\": -74.0060,\n  \"dropoffAddress\": \"456 Broadway, New York, NY\",\n  \"dropoffLat\": 40.7580,\n  \"dropoffLng\": -73.9855,\n  \"truckTypeId\": \"<truck-type-id>\",\n  \"targetDriverId\": \"<driver-user-id>\",\n  \"workNote\": \"Handle with care\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/jobs", "host": ["{{baseUrl}}"], "path": ["jobs"] }
          }
        },
        {
          "name": "Get Home Page Data",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/jobs/home", "host": ["{{baseUrl}}"], "path": ["jobs", "home"] }
          }
        },
        {
          "name": "Get Nearby Drivers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/jobs/nearby-drivers?truckTypeId=<id>&lat=40.7128&lng=-74.0060&radiusKm=20",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "nearby-drivers"],
              "query": [
                { "key": "truckTypeId", "value": "<id>" },
                { "key": "lat", "value": "40.7128" },
                { "key": "lng", "value": "-74.0060" },
                { "key": "radiusKm", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get My Jobs (Customer)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/jobs/my-jobs?status=BROADCAST",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "my-jobs"],
              "query": [
                { "key": "status", "value": "BROADCAST", "description": "PENDING | BROADCAST | BOOKED | ON_WAY | ARRIVED | LOADED | IN_TRANSIT | DELIVERED | CANCELLED" }
              ]
            }
          }
        },
        {
          "name": "Get Driver Jobs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/jobs/driver-jobs",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "driver-jobs"],
              "query": [
                { "key": "status", "value": "", "disabled": true, "description": "PENDING | BROADCAST | BOOKED | ON_WAY | ARRIVED | LOADED | IN_TRANSIT | DELIVERED | CANCELLED" }
              ]
            }
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/jobs/:id", "host": ["{{baseUrl}}"], "path": ["jobs", ":id"], "variable": [{ "key": "id", "value": "<job-id>" }] }
          }
        },
        {
          "name": "Accept Job (Driver)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/jobs/:id/accept", "host": ["{{baseUrl}}"], "path": ["jobs", ":id", "accept"], "variable": [{ "key": "id", "value": "<job-id>" }] }
          }
        },
        {
          "name": "Advance Job Status (Driver)",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/jobs/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", ":id", "status"],
              "variable": [{ "key": "id", "value": "<job-id>" }]
            },
            "description": "Advances job through: BOOKED → ON_WAY → ARRIVED → LOADED → IN_TRANSIT → DELIVERED"
          }
        },
        {
          "name": "Cancel Job (Customer)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/jobs/:id/cancel", "host": ["{{baseUrl}}"], "path": ["jobs", ":id", "cancel"], "variable": [{ "key": "id", "value": "<job-id>" }] }
          }
        },
        {
          "name": "Submit Review (Customer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Great driver, very professional!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/jobs/:id/review", "host": ["{{baseUrl}}"], "path": ["jobs", ":id", "review"], "variable": [{ "key": "id", "value": "<job-id>" }] }
          }
        }
      ]
    },
    {
      "name": "Payment",
      "item": [
        {
          "name": "Create Payment Intent",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/payment/job/:jobId/intent",
              "host": ["{{baseUrl}}"],
              "path": ["payment", "job", ":jobId", "intent"],
              "variable": [{ "key": "jobId", "value": "<delivered-job-id>" }]
            },
            "description": "Job must be in DELIVERED status and driver must have completed Stripe onboarding."
          }
        },
        {
          "name": "Stripe Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "stripe-signature", "value": "<stripe-signature>" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"type\": \"payment_intent.succeeded\", \"data\": { \"object\": {} } }"
            },
            "url": { "raw": "{{baseUrl}}/payment/webhook", "host": ["{{baseUrl}}"], "path": ["payment", "webhook"] },
            "description": "Called by Stripe — use Stripe CLI to test locally.\nHandles: payment_intent.succeeded, account.updated"
          }
        }
      ]
    },
    {
      "name": "Withdrawals",
      "item": [
        {
          "name": "Request Withdrawal (Driver)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/withdrawals/request", "host": ["{{baseUrl}}"], "path": ["withdrawals", "request"] },
            "description": "Minimum $10. Driver must have completed Stripe onboarding. Balance is reserved immediately; payout is processed only after admin approval."
          }
        },
        {
          "name": "Get Withdrawal History (Driver)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/withdrawals/history", "host": ["{{baseUrl}}"], "path": ["withdrawals", "history"] }
          }
        },
        {
          "name": "Get Withdrawal Status (Driver / Admin)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/withdrawals/:withdrawalId", "host": ["{{baseUrl}}"], "path": ["withdrawals", ":withdrawalId"], "variable": [{ "key": "withdrawalId", "value": "<withdrawal-id>" }] }
          }
        },
        {
          "name": "Approve Withdrawal (Admin)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/withdrawals/:withdrawalId/approve", "host": ["{{baseUrl}}"], "path": ["withdrawals", ":withdrawalId", "approve"], "variable": [{ "key": "withdrawalId", "value": "<withdrawal-id>" }] },
            "description": "Queues a Stripe transfer from the platform balance to the driver's connected account."
          }
        },
        {
          "name": "Reject Withdrawal (Admin)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/withdrawals/:withdrawalId/reject", "host": ["{{baseUrl}}"], "path": ["withdrawals", ":withdrawalId", "reject"], "variable": [{ "key": "withdrawalId", "value": "<withdrawal-id>" }] },
            "description": "Rejects the withdrawal and restores the reserved balance back to the driver."
          }
        }
      ]
    },
