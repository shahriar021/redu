{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@env": [
        "./env.d.ts"
      ],
      "expo-modules-core": [
        "./node_modules/expo/node_modules/expo-modules-core"
      ],
      "expo-modules-core/*": [
        "./node_modules/expo/node_modules/expo-modules-core/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "env.d.ts",
    "nativewind-env.d.ts"
  ]
}
